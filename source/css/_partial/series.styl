// 系列文章相关样式

// 系列导航组件
.series-navigation
  margin: 2rem 0
  padding: 1.5rem
  border: 1px solid #e0e0e0
  border-radius: 8px
  background: #fafafa

  @media (prefers-color-scheme: dark)
    border-color: #444
    background: #1a1a1a

.series-title
  margin: 0 0 1rem 0
  font-size: 1.2rem
  color: #333

  @media (prefers-color-scheme: dark)
    color: #ccc

.series-nav
  display: flex
  justify-content: space-between
  gap: 1rem

  @media (max-width: 768px)
    flex-direction: column

.series-nav-prev,
.series-nav-next
  flex: 1
  padding: 1rem
  border-radius: 6px
  text-decoration: none
  transition: all 0.3s ease
  display: flex
  flex-direction: column
  gap: 0.5rem

.series-nav-prev
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
  color: white

  &:hover
    transform: translateY(-2px)
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4)

.series-nav-next
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%)
  color: white
  text-align: right

  &:hover
    transform: translateY(-2px)
    box-shadow: 0 4px 12px rgba(245, 87, 108, 0.4)

.nav-label
  font-size: 0.85rem
  opacity: 0.9

.nav-title
  font-weight: 600
  font-size: 1rem

// 系列列表组件
.series-list
  margin: 2rem 0
  padding: 1.5rem
  border: 1px solid #e0e0e0
  border-radius: 8px
  background: #fafafa

  @media (prefers-color-scheme: dark)
    border-color: #444
    background: #1a1a1a

.series-list-title
  margin: 0 0 1rem 0
  font-size: 1.2rem
  color: #333

  @media (prefers-color-scheme: dark)
    color: #ccc

.series-list-items
  list-style: none
  padding: 0
  margin: 0

.series-list-item
  padding: 0.75rem 0
  border-bottom: 1px solid #eee

  @media (prefers-color-scheme: dark)
    border-bottom-color: #333

  &:last-child
    border-bottom: none

  &.active .series-link
    color: #667eea
    font-weight: 600

    @media (prefers-color-scheme: dark)
      color: #8da6f5

.series-order
  display: inline-block
  min-width: 2rem
  color: #999
  font-weight: 500

  @media (prefers-color-scheme: dark)
    color: #666

.series-link
  color: #555
  text-decoration: none
  transition: color 0.3s ease

  @media (prefers-color-scheme: dark)
    color: #aaa

  &:hover
    color: #667eea

    @media (prefers-color-scheme: dark)
      color: #8da6f5

// 分类/标签页面样式
.category-header,
.tag-header
  text-align: center
  padding: 2rem 0
  margin-bottom: 2rem
  border-bottom: 2px solid #e0e0e0

  @media (prefers-color-scheme: dark)
    border-bottom-color: #333

.category-title,
.tag-title
  font-size: 2rem
  margin: 0 0 0.5rem 0
  color: #333

  @media (prefers-color-scheme: dark)
    color: #ccc

.category-count,
.tag-count
  color: #666
  font-size: 1rem

  @media (prefers-color-scheme: dark)
    color: #999

// 分类/标签索引页样式
.categories-index,
.tags-index
  padding: 2rem 0

  h2
    text-align: center
    font-size: 1.8rem
    margin-bottom: 2rem
    color: #333

    @media (prefers-color-scheme: dark)
      color: #ccc

.categories-list a,
.tags-list a
  display: inline-block
  padding: 0.5rem 1rem
  margin: 0.25rem
  background: #f0f0f0
  border-radius: 20px
  color: #555
  text-decoration: none
  transition: all 0.3s ease

  @media (prefers-color-scheme: dark)
    background: #333
    color: #aaa

  &:hover
    background: #667eea
    color: white
    transform: translateY(-2px)
